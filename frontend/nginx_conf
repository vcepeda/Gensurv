# Gensurv service from Vicky
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name gensurv.de;

    ssl_certificate /etc/letsencrypt/live/gensurv.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gensurv.de/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location /static/ {
        alias /mnt/web_data/html/Gensurv/backend/staticfiles/;

	#    alias /mnt/web_data/html/Gensurv/static/;
    }

    location /media/ {
        alias /mnt/storage/ahcepev1/Gensurv_data/media/;
    }

    error_log /var/log/nginx/gensurv_error.log;
    access_log /var/log/nginx/gensurv_access.log;

    location /app/ {
    	alias /mnt/web_data/html/Gensurv/frontend/dist/;
        try_files $uri $uri/ /app/index.html;
    }

    location / {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    ssl_certificate /etc/letsencrypt/live/gensurv.de/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/gensurv.de/privkey.pem; # managed by Certbot
}

# Redirect HTTP to HTTPS
server {
    if ($host = gensurv.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name gensurv.de;
    return 301 https://$host$request_uri;

}

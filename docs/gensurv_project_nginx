#Remember to replace the IP with your server's IP address and /path/ with the actual path to your project and static files.
server {
    server_name gensurv.de IP;

    location = /favicon.ico { access_log off; log_not_found off; }
    location /static/ {
        alias /path/staticfiles/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/path/gensurv_project.sock;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/gensurv.de/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/gensurv.de/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    if ($host = gensurv.de) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name gensurv.de IP;
    return 404; # managed by Certbot

}
